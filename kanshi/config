profile single {
    output eDP-1 mode 1920x1200 enable
    exec swaymsg 'workspace 1 output eDP-1'
    exec swaymsg 'workspace 2 output eDP-1'
    exec swaymsg 'workspace 3 output eDP-1'
    exec swaymsg 'workspace 4 output eDP-1'
    exec swaymsg 'workspace 5 output eDP-1'
    exec swaymsg 'workspace 6 output eDP-1'
    exec swaymsg 'workspace 7 output eDP-1'
    exec swaymsg 'workspace 8 output eDP-1'
    exec swaymsg 'workspace 9 output eDP-1'
    exec swaymsg 'workspace 10 output eDP-1'
}

profile dual {
    output HDMI-A-1 mode 1920x1080 position 0,0 enable
    output eDP-1   mode 1920x1200 position 1920,0 enable
    exec swaymsg 'workspace 1 output HDMI-A-1'
    exec swaymsg 'workspace 2 output HDMI-A-1'
    exec swaymsg 'workspace 3 output HDMI-A-1'
    exec swaymsg 'workspace 4 output HDMI-A-1'
    exec swaymsg 'workspace 5 output HDMI-A-1'
    exec swaymsg 'workspace 6 output eDP-1'
    exec swaymsg 'workspace 7 output eDP-1'
    exec swaymsg 'workspace 8 output eDP-1'
    exec swaymsg 'workspace 9 output eDP-1'
    exec swaymsg 'workspace 10 output eDP-1'
}
