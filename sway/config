### Decorations

# gaps
gaps inner 10
gaps outer 10
smart_gaps true

# bordes
default_border pixel 1
hide_edge_borders smart

# colors
client.focused #ffffff #ffffff #ffffff #ffffff

# wallpaper
exec_always swaybg -i ~/.config/sway/wp1.png

# Status Bar
bar {
    swaybar_command waybar
}



### Assigning to workspaces

assign [class="AmneziaVPN"] workspace number 10
assign [app_id=".*qbittorrent.*"] workspace number 10
for_window [class="^Steam$"] move to workspace 6
for_window [instance="steamwebhelper"] move to workspace 6
# for_window [title=".*Steam.*"] move to workspace 6
for_window [class="SteamUpdate"] move to workspace 6
for_window [window_role="update"] move to workspace 6


include ~/.config/sway/*.conf
